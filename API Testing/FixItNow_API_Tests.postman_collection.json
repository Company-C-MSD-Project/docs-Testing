                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) pm.environment.set('serviceId', pm.response.json().data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Pipe Leak Repair\",\n  \"description\": \"Fix leaking pipes\",\n  \"dayPayment\": 3500.00,\n  \"isActive\": true\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/services/category/{{categoryId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "services", "category", "{{categoryId}}"]
            }
          }
