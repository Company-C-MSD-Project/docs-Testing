        {
          "name": "Get All Services",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/services", "host": ["{{baseUrl}}"], "path": ["api", "services"] }
          }
        }
      ]
    },
    {
      "name": "4. Smart Match",
      "item": [
        {
          "name": "Find Matching Providers",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns an array', () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{homeownerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/bookings/match?category=Plumbing&lat=6.9271&lng=79.8612",
              "host": ["{{baseUrl}}"], "path": ["api", "bookings", "match"],
              "query": [
                { "key": "category", "value": "Plumbing" },
                { "key": "lat", "value": "6.9271" },
                { "key": "lng", "value": "79.8612" }
              ]
            }
          }
        },
        {
          "name": "Match Without Token (should fail)",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status is 401 or 403', () => pm.expect(pm.response.code).to.be.oneOf([401, 403]));"], "type": "text/javascript" } }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/bookings/match?category=Plumbing&lat=6.9271&lng=79.8612",
              "host": ["{{baseUrl}}"], "path": ["api", "bookings", "match"],
              "query": [
                { "key": "category", "value": "Plumbing" },
                { "key": "lat", "value": "6.9271" },
                { "key": "lng", "value": "79.8612" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "5. Bookings",
      "item": [
        {
          "name": "Create Booking (Homeowner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Status field is PENDING', () => {",
                  "    pm.expect(pm.response.json().data.status).to.eql('PENDING');",
                  "});",
                  "if (pm.response.code === 201) pm.environment.set('bookingId', pm.response.json().data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{homeownerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": {{serviceId}},\n  \"providerId\": {{providerId}},\n  \"scheduledDate\": \"2026-07-01T10:00:00\",\n  \"description\": \"Kitchen pipe is leaking badly.\",\n  \"serviceType\": \"Plumbing\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bookings?homeownerId={{homeownerId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "bookings"],
              "query": [{ "key": "homeownerId", "value": "{{homeownerId}}" }]
            }
          }
        },
        {
          "name": "Create Booking as Provider (should fail - wrong role)",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status is 403 Forbidden', () => pm.response.to.have.status(403));"], "type": "text/javascript" } }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{providerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": {{serviceId}},\n  \"providerId\": {{providerId}},\n  \"scheduledDate\": \"2026-07-01T10:00:00\",\n  \"description\": \"Should not be allowed.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bookings?homeownerId={{homeownerId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "bookings"],
              "query": [{ "key": "homeownerId", "value": "{{homeownerId}}" }]
            }
          }
        },
        {
          "name": "Get Booking By Id",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{homeownerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["api", "bookings", "{{bookingId}}"] }
          }
        },
        {
          "name": "Accept Booking (Provider)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status field is ACCEPTED', () => {",
                  "    pm.expect(pm.response.json().data.status).to.eql('ACCEPTED');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/accept?providerId={{providerId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "bookings", "{{bookingId}}", "accept"],
              "query": [{ "key": "providerId", "value": "{{providerId}}" }]
            }
          }
        },
        {
          "name": "Accept Already-Accepted Booking (should fail)",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status is 400 Bad Request', () => pm.response.to.have.status(400));"], "type": "text/javascript" } }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/accept?providerId={{providerId}}",
              "host": ["{{baseUrl}}"], "path": ["api", "bookings", "{{bookingId}}", "accept"],
              "query": [{ "key": "providerId", "value": "{{providerId}}" }]
            }
          }
        },
        {
          "name": "Start Job (Provider)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status field is IN_PROGRESS', () => {",
                  "    pm.expect(pm.response.json().data.status).to.eql('IN_PROGRESS');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/start", "host": ["{{baseUrl}}"], "path": ["api", "bookings", "{{bookingId}}", "start"] }
          }
        },
        {
          "name": "Complete Job (Provider)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status field is COMPLETED', () => {",
                  "    pm.expect(pm.response.json().data.status).to.eql('COMPLETED');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/complete", "host": ["{{baseUrl}}"], "path": ["api", "bookings", "{{bookingId}}", "complete"] }
          }
        },
        {
          "name": "Get Bookings By Homeowner",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{homeownerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/homeowner/{{homeownerId}}", "host": ["{{baseUrl}}"], "path": ["api", "bookings", "homeowner", "{{homeownerId}}"] }
          }
        },
        {
          "name": "Get Bookings By Provider",
