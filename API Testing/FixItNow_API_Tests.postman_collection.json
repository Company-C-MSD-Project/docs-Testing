{
  "info": {
    "name": "FixItNow API Tests",
    "description": "API test suite for the FixItNow backend. Covers Auth, Bookings, Smart Match, Payments, Reviews, Notifications, Disputes, Categories, Services, and Admin endpoints.\n\nHOW TO USE:\n1. Import this collection AND the companion environment file into Postman.\n2. Select the 'FixItNow Local' environment (top-right dropdown).\n3. Run requests in order from top to bottom inside each folder — later requests reuse IDs/tokens saved automatically by earlier ones.\n4. Use the 'Runner' (Collection > ... > Run collection) to execute everything in one click and see a pass/fail report.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register Homeowner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response has success true', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "});",
                  "pm.test('User type is HOMEOWNER', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.userType).to.eql('HOMEOWNER');",
                  "});",
                  "pm.test('Password hash is never returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.passwordHash).to.be.null;",
                  "});",
                  "if (pm.response.code === 201) {",
                  "    pm.environment.set('homeownerId', pm.response.json().data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Homeowner\",\n  \"email\": \"alice.{{$randomInt}}@fixitnow.test\",\n  \"username\": \"alice_{{$randomInt}}\",\n  \"password\": \"SecurePass1!\",\n  \"phone\": \"0771234567\",\n  \"address\": \"12 Main St, Colombo\",\n  \"userType\": \"HOMEOWNER\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Register Service Provider",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Provider starts unverified', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.verified).to.be.false;",
                  "});",
                  "if (pm.response.code === 201) {",
                  "    pm.environment.set('providerId', pm.response.json().data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Provider\",\n  \"email\": \"bob.{{$randomInt}}@fixitnow.test\",\n  \"username\": \"bob_{{$randomInt}}\",\n  \"password\": \"ProvPass99!\",\n  \"phone\": \"0779876543\",\n  \"userType\": \"SERVICE_PROVIDER\",\n  \"serviceCategory\": \"Plumbing\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Register Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) {",
                  "    pm.environment.set('adminId', pm.response.json().data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Carol Admin\",\n  \"email\": \"carol.{{$randomInt}}@fixitnow.test\",\n  \"username\": \"carol_{{$randomInt}}\",\n  \"password\": \"AdminPass1!\",\n  \"userType\": \"ADMIN\",\n  \"department\": \"Operations\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Register Duplicate Email (should fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400 Bad Request', () => pm.response.to.have.status(400));",
                  "pm.test('Error mentions already registered', () => {",
                  "    pm.expect(pm.response.text()).to.include('already registered');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Duplicate Alice\",\n  \"email\": \"duplicate@fixitnow.test\",\n  \"username\": \"dupuser1\",\n  \"password\": \"SecurePass1!\",\n  \"userType\": \"HOMEOWNER\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "description": "Run this request TWICE in a row. The second run should fail with 400."
          }
        },
        {
          "name": "Login Homeowner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token is present', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.token).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('Token type is Bearer', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.tokenType).to.eql('Bearer');",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('homeownerToken', json.data.token);",
                  "    pm.environment.set('homeownerId', json.data.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usernameOrEmail\": \"{{homeownerEmail}}\",\n  \"password\": \"SecurePass1!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "description": "NOTE: Set 'homeownerEmail' in the environment to match the email used in 'Register Homeowner' before running this. Or replace {{homeownerEmail}} with a known seeded user."
          }
        },
        {
          "name": "Login Wrong Password (should fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401 Unauthorized', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usernameOrEmail\": \"{{homeownerEmail}}\",\n  \"password\": \"WrongPassword!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Login Provider",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('providerToken', json.data.token);",
                  "    pm.environment.set('providerId', json.data.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usernameOrEmail\": \"{{providerEmail}}\",\n  \"password\": \"ProvPass99!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('adminToken', json.data.token);",
                  "    pm.environment.set('adminId', json.data.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usernameOrEmail\": \"{{adminEmail}}\",\n  \"password\": \"AdminPass1!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "2. Admin Setup (verify provider)",
      "item": [
        {
          "name": "Verify Provider",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Provider is now verified', () => {",
                  "    pm.expect(pm.response.json().data.verified).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/providers/{{providerId}}/verify",
              "host": ["{{baseUrl}}"], "path": ["api", "admin", "providers", "{{providerId}}", "verify"]
            }
          }
        },
        {
          "name": "Get Pending Providers",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/providers/pending", "host": ["{{baseUrl}}"], "path": ["api", "admin", "providers", "pending"] }
          }
        },
        {
          "name": "Get Analytics",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Contains totalUsers field', () => {",
                  "    pm.expect(pm.response.json().data).to.have.property('totalUsers');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/analytics", "host": ["{{baseUrl}}"], "path": ["api", "admin", "analytics"] }
          }
        },
        {
          "name": "Admin Endpoint Without Token (should fail)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 401 or 403', () => pm.expect(pm.response.code).to.be.oneOf([401, 403]));"], "type": "text/javascript" }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/admin/analytics", "host": ["{{baseUrl}}"], "path": ["api", "admin", "analytics"] }
          }
        }
      ]
    },
    {
      "name": "3. Categories & Services",
      "item": [
        {
          "name": "Create Category (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) pm.environment.set('categoryId', pm.response.json().data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Plumbing\",\n  \"description\": \"Pipe repairs, leaks, installations\",\n  \"isActive\": true\n}" },
            "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api", "categories"] }
          }
        },
        {
          "name": "Get All Categories",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api", "categories"] }
          }
        },
        {
          "name": "Create Service Under Category (Admin)",
          "event": [
            {
              "listen": "test",
